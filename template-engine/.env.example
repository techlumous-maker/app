# Slug of the template to render, matching a key in templates/registry.ts.
# If unset, the first registered template is used.
TEMPLATE_SLUG=hello-world

# Supabase pointers for runtime content. All three are optional locally —
# when any is unset the template renders its defaultContent instead.
# On a deployed site they identify the published `site` row to fetch
# (anon key + RLS: only published rows are readable).
SUPABASE_URL=
SUPABASE_ANON_KEY=
SITE_ID=
